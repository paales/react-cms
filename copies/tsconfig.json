{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@parton/copies": ["./index.ts"],
      "@parton/copies/*": ["./src/*"]
    }
  },
  "include": ["src", "index.ts"],
  // `ai-elements/` is vendored upstream (Vercel AI Elements), not yet
  // wired into any app (`index.ts` is an empty stub — nothing imports
  // it), and carries type drift against the installed
  // @base-ui-components version. Excluded from the strict typecheck
  // until it's actually used and updated; the shadcn `ui/`, `hooks/`,
  // and `lib/` primitives ARE checked.
  "exclude": ["src/components/ai-elements"]
}
