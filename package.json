{
  "name": "react-cms",
  "packageManager": "yarn@4.14.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework",
    "cms",
    "copies",
    "e2e-testing",
    "e2e-magento",
    "docs"
  ],
  "scripts": {
    "dev": "yarn workspace @react-cms/e2e-testing dev",
    "dev:clean": "yarn workspace @react-cms/e2e-testing dev --mode clean",
    "dev:magento": "yarn workspace @react-cms/e2e-magento dev",
    "build": "yarn workspace @react-cms/e2e-testing build",
    "build:magento": "yarn workspace @react-cms/e2e-magento build",
    "preview": "yarn workspace @react-cms/e2e-testing preview",
    "test": "yarn test:node && yarn test:rsc",
    "test:node": "vitest run --project=node",
    "test:rsc": "NODE_OPTIONS='--conditions=react-server' vitest run --project=rsc",
    "test:browser": "vitest run --project=browser",
    "test:all": "yarn test:node && yarn test:rsc && yarn test:browser",
    "test:watch": "vitest --project=node",
    "test:watch:rsc": "NODE_OPTIONS='--conditions=react-server' vitest --project=rsc",
    "test:e2e": "playwright test",
    "gql:generate": "yarn workspace @react-cms/e2e-testing gql:generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.28.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@types/node": "^25.6.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.168",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.13.2",
    "graphql-config": "^5.1.6",
    "graphql-request": "^7.4.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.9.0",
    "media-chrome": "^4.19.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next-themes": "^0.4.6",
    "prettier": "^3.8.3",
    "react": "19.3.0-canary-00f063c3-20260415",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.3.0-canary-00f063c3-20260415",
    "react-jsx-parser": "^2.4.1",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.4.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "@vitejs/plugin-rsc": "^0.5.24",
    "@vitest/browser": "3.2.4",
    "gql.tada": "^1.9.2",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "rsc-html-stream": "^0.0.7",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.3",
    "vitest": "^3.1.4"
  }
}
