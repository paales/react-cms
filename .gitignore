.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
node_modules
dist

# Playwright
test-results/
playwright-report/
.last-run.json

# CMS — author-local draft overrides; created on-demand by the editor.
# Published content lives in `cms/data/content.json` (committed).
cms/data/draft.json

# Cells — runtime-mutable per-process state. Default scope writes
# through to disk so streaming-demo state survives HMR; test scopes
# stay in memory. Don't commit; users get fresh state on first run.
cms/data/cells.json

# Claude Code harness runtime artifacts.
.claude/
