.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
node_modules
dist

# Playwright
test-results/
playwright-report/
.last-run.json

# CMS — author-local draft overrides; created on-demand by the editor.
# Published content lives in `cms/data/content.json` (committed).
cms/data/draft.json

# Cells — runtime-mutable per-process state. Default scope writes
# through to disk so streaming-demo state survives HMR; test scopes
# stay in memory. Don't commit; users get fresh state on first run.
cms/data/cells.json

# Claude Code harness runtime artifacts.
.claude/

# Scratch / throwaway logs.
.tmp/

# Server benchmark artifacts. The committed baseline JSON
# (bench/results/server-warm-tick.json) is the regression substrate;
# CPU profiles and scratch logs are machine-specific and stay local.
bench/results/prof/
bench/results/*.log
bench/results/baseline.json
bench/results/*.scratch.json

# Client-scroll benchmark artifacts (bench/client-scroll.mjs) — DevTools
# traces + CPU profiles + per-run summaries. Large and machine-specific;
# the harness prints their paths, they never commit.
bench/results/client/

# GraphQL record/replay store for the e2e harness (see
# e2e-testing/src/app/gql-disk-cache.ts). Machine-local; delete to
# re-record.
.gql-cache/
