{
  "partials": {
    "cms-demo-hero": {
      "id": "cms-demo-hero",
      "displayName": "#hero",
      "configs": [
        {
          "match": {},
          "fields": {
            "headline": "Welcome to the CMS demo",
            "subhead": "Every field on this page is read through accessor-tracked calls. Edit src/cms/content.json and reload to see changes.",
            "tone": "calm"
          }
        }
      ]
    },
    "cms-demo-greeting": {
      "id": "cms-demo-greeting",
      "displayName": "#greeting",
      "configs": [
        {
          "match": {
            "pathname:/cms-demo/:slug": {
              "slug": "alpha"
            }
          },
          "fields": {
            "headline": "Hello, Alpha!",
            "body": "This config matches only when the URL slug is 'alpha'.",
            "tone": "loud",
            "accent": 3
          }
        },
        {
          "match": {
            "pathname:/cms-demo/:slug": {
              "slug": {
                "in": [
                  "beta",
                  "gamma"
                ]
              }
            }
          },
          "fields": {
            "headline": "Beta/Gamma view",
            "body": "This config matches for 'beta' OR 'gamma' via the {in: [...]} clause."
          }
        },
        {
          "match": {},
          "fields": {
            "headline": "Default greeting",
            "body": "Visit /cms-demo/alpha, /cms-demo/beta, or /cms-demo/zulu to see cascade resolution in action.",
            "tone": "calm",
            "accent": 1
          }
        }
      ]
    },
    "cms-demo-composed": {
      "id": "cms-demo-composed",
      "displayName": "#composed",
      "configs": [
        {
          "match": {},
          "fields": {}
        }
      ],
      "slots": {
        "body": [
          {
            "id": "composed-hero-1",
            "type": "hero",
            "configs": [
              {
                "match": {},
                "fields": {
                  "headline": "First hero in the body slot",
                  "subhead": "Composed from a <Children> slot via the block registry.",
                  "tone": "calm"
                }
              }
            ]
          },
          {
            "id": "composed-text-1",
            "type": "rich-text",
            "configs": [
              {
                "match": {},
                "fields": {
                  "body": "This rich-text block is the second entry in the body slot. Ordering comes from content.json; each entry resolves its own fields through the CMS scope opened by <Partial cmsId>."
                }
              }
            ]
          },
          {
            "id": "composed-hero-2",
            "type": "hero",
            "configs": [
              {
                "match": {
                  "pathname:/cms-demo/:slug": {
                    "slug": "alpha"
                  }
                },
                "fields": {
                  "headline": "Alpha-only third block",
                  "subhead": "Per-slug cascade works on slot children too.",
                  "tone": "loud"
                }
              },
              {
                "match": {},
                "fields": {
                  "headline": "Third block (default)",
                  "subhead": "Falls through when the slug doesn't match.",
                  "tone": "calm"
                }
              }
            ]
          }
        ]
      }
    },
    "cms-demo-multi-slot": {
      "id": "cms-demo-multi-slot",
      "displayName": "#multi-slot",
      "configs": [
        {
          "match": {},
          "fields": {}
        }
      ],
      "slots": {
        "body": [
          {
            "id": "multi-body-1",
            "type": "rich-text",
            "configs": [
              {
                "match": {},
                "fields": {
                  "body": "Body slot — primary content."
                }
              }
            ]
          }
        ],
        "sidebar": [
          {
            "id": "multi-sidebar-1",
            "type": "hero",
            "configs": [
              {
                "match": {},
                "fields": {
                  "headline": "Sidebar slot",
                  "subhead": "Secondary content lane."
                }
              }
            ]
          }
        ]
      }
    }
  }
}
